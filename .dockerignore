# ─── Docker build ignores ────────────────────────────────────────────────────
# Reduce build context size by excluding unnecessary files

venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# ML model files (downloaded from HF Hub at runtime)
backend/ml/models/*.pkl
backend/ml/models/*.h5
backend/ml/models/*.keras

# SQLite DB (fresh one created on each deploy)
backend/db.sqlite3

# IDE / OS files
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Misc
temp_uploads/
dataset/
*.ipynb
*.ipynb_checkpoints/
MediSkin_AI*.ipynb
*.bat
vercel.json
HF_README.md

# Backend venv (nested)
backend/venv/
