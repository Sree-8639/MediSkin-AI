# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com,.vercel.app,yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
# On Render, this is automatically set. Leave empty for local SQLite development.
DATABASE_URL=

# ─── CORS Configuration (Frontend-Backend Connection) ─────────────────────────
# List of origins allowed to make requests to this backend
# Format: comma-separated URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173,https://yourvercel-app.vercel.app,https://yourdomain.com

# ─── Email Configuration (Password Reset, Notifications) ───────────────────────
# Gmail SMTP - use app-specific password here
EMAIL_HOST_USER=mediskinai@gmail.com
EMAIL_HOST_PASSWORD=[YOUR_GMAIL_APP_PASSWORD]
DEFAULT_FROM_EMAIL=MediSkin AI <mediskinai@gmail.com>

# ─── Google OAuth 2.0 Configuration ───────────────────────────────────────────
# Get these from Google Cloud Console (APIs & Services > Credentials)
# Not required for basic deployment, but needed for Google sign-in feature
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# ─── Site Framework (django.contrib.sites) ─────────────────────────────────────
SITE_ID=1

# ─── Deployment Environment ────────────────────────────────────────────────────
ENVIRONMENT=development
